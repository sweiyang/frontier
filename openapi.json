{
  "components": {
    "schemas": {
      "Agent": {
        "properties": {
          "id": {
            "type": "integer"
          },
          "is_default": {
            "type": "boolean"
          },
          "name": {
            "example": "GPT-4 Agent",
            "type": "string"
          },
          "project_id": {
            "type": "integer"
          },
          "type": {
            "enum": [
              "langgraph",
              "openai",
              "http"
            ],
            "example": "openai",
            "type": "string"
          },
          "url": {
            "example": "https://api.openai.com/v1",
            "type": "string"
          }
        },
        "type": "object"
      },
      "AgentCreate": {
        "properties": {
          "auth": {
            "description": "Authentication configuration (auth_type, credentials)",
            "type": "object"
          },
          "extras": {
            "description": "Connector-specific configuration",
            "type": "object"
          },
          "is_default": {
            "default": false,
            "type": "boolean"
          },
          "name": {
            "example": "My Custom Agent",
            "type": "string"
          },
          "project_id": {
            "type": "integer"
          },
          "type": {
            "enum": [
              "langgraph",
              "openai",
              "http"
            ],
            "type": "string"
          },
          "url": {
            "example": "https://api.example.com",
            "type": "string"
          }
        },
        "required": [
          "name",
          "type",
          "url",
          "project_id"
        ],
        "type": "object"
      },
      "ChatRequest": {
        "properties": {
          "agent_id": {
            "example": 1,
            "type": "integer"
          },
          "conversation_id": {
            "example": "conv-123",
            "type": "string"
          },
          "files": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "message": {
            "example": "What is the weather today?",
            "type": "string"
          },
          "model": {
            "example": "gpt-4",
            "type": "string"
          }
        },
        "required": [
          "conversation_id",
          "message"
        ],
        "type": "object"
      },
      "Conversation": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "example": "conv-123",
            "type": "string"
          },
          "title": {
            "example": "Weather Discussion",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ConversationCreate": {
        "properties": {
          "title": {
            "example": "New Conversation",
            "type": "string"
          }
        },
        "required": [
          "title"
        ],
        "type": "object"
      },
      "ConversationDetail": {
        "properties": {
          "id": {
            "type": "string"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/Message"
            },
            "type": "array"
          },
          "title": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "password": {
            "example": "password123",
            "format": "password",
            "type": "string"
          },
          "username": {
            "example": "john.doe",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "type": "object"
      },
      "Message": {
        "properties": {
          "content": {
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "role": {
            "enum": [
              "user",
              "assistant",
              "system"
            ],
            "type": "string"
          },
          "token_count": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "Project": {
        "properties": {
          "description": {
            "type": "string"
          },
          "disable_authentication": {
            "type": "boolean"
          },
          "disable_message_storage": {
            "type": "boolean"
          },
          "id": {
            "example": 1,
            "type": "integer"
          },
          "is_admin": {
            "description": "Whether current user has admin access",
            "type": "boolean"
          },
          "name": {
            "example": "my-ai-project",
            "type": "string"
          },
          "owner_id": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ProjectCreate": {
        "properties": {
          "disable_authentication": {
            "default": false,
            "type": "boolean"
          },
          "disable_message_storage": {
            "default": false,
            "type": "boolean"
          },
          "project_name": {
            "example": "my-ai-project",
            "type": "string"
          }
        },
        "required": [
          "project_name"
        ],
        "type": "object"
      },
      "ProjectUpdate": {
        "properties": {
          "description": {
            "type": "string"
          },
          "disable_authentication": {
            "type": "boolean"
          },
          "disable_message_storage": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "string"
          },
          "token_type": {
            "example": "bearer",
            "type": "string"
          },
          "user_id": {
            "example": 1,
            "type": "integer"
          },
          "username": {
            "example": "john.doe",
            "type": "string"
          }
        },
        "type": "object"
      },
      "User": {
        "properties": {
          "user_id": {
            "example": 1,
            "type": "integer"
          },
          "username": {
            "example": "john.doe",
            "type": "string"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Frontier Team"
    },
    "description": "Multi-project AI chat platform with RBAC, LDAP integration, and pluggable agent connectors",
    "title": "Frontier API",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/agents": {
      "get": {
        "description": "List all agents for a project",
        "operationId": "listAgents",
        "parameters": [
          {
            "in": "query",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Agent"
                  },
                  "type": "array"
                }
              }
            },
            "description": "List of agents"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List agents",
        "tags": [
          "agents"
        ]
      },
      "post": {
        "description": "Create a new agent configuration",
        "operationId": "createAgent",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            },
            "description": "Agent created"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create agent",
        "tags": [
          "agents"
        ]
      }
    },
    "/chat": {
      "post": {
        "description": "Stream chat response using Server-Sent Events (SSE)",
        "operationId": "streamChat",
        "parameters": [
          {
            "description": "Project name for context",
            "in": "header",
            "name": "X-Project-Name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "SSE stream of chat response"
          },
          "400": {
            "description": "Bad request - project name required"
          },
          "404": {
            "description": "No agent configured"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Stream chat",
        "tags": [
          "chat"
        ]
      }
    },
    "/conversations": {
      "get": {
        "description": "List all conversations for a project",
        "operationId": "listConversations",
        "parameters": [
          {
            "in": "header",
            "name": "X-Project-Name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Conversation"
                  },
                  "type": "array"
                }
              }
            },
            "description": "List of conversations"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List conversations",
        "tags": [
          "conversations"
        ]
      },
      "post": {
        "description": "Create a new conversation",
        "operationId": "createConversation",
        "parameters": [
          {
            "in": "header",
            "name": "X-Project-Name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversationCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conversation"
                }
              }
            },
            "description": "Conversation created"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create conversation",
        "tags": [
          "conversations"
        ]
      }
    },
    "/conversations/{conversation_id}": {
      "delete": {
        "description": "Delete a conversation and all its messages",
        "operationId": "deleteConversation",
        "parameters": [
          {
            "in": "path",
            "name": "conversation_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "X-Project-Name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation deleted"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Delete conversation",
        "tags": [
          "conversations"
        ]
      },
      "get": {
        "description": "Get conversation details and messages",
        "operationId": "getConversation",
        "parameters": [
          {
            "in": "path",
            "name": "conversation_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "X-Project-Name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetail"
                }
              }
            },
            "description": "Conversation details"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get conversation",
        "tags": [
          "conversations"
        ]
      }
    },
    "/login": {
      "post": {
        "description": "Authenticate user via LDAP and return JWT token",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            },
            "description": "Successful authentication"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "summary": "User login",
        "tags": [
          "auth"
        ]
      }
    },
    "/logout": {
      "post": {
        "description": "Logout the current user",
        "operationId": "logout",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful logout"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "User logout",
        "tags": [
          "auth"
        ]
      }
    },
    "/me": {
      "get": {
        "description": "Get current authenticated user info",
        "operationId": "getCurrentUser",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            },
            "description": "Current user information"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get current user",
        "tags": [
          "auth"
        ]
      }
    },
    "/projects": {
      "post": {
        "description": "Create a new project for the authenticated user",
        "operationId": "createProject",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            },
            "description": "Project created successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create project",
        "tags": [
          "projects"
        ]
      }
    },
    "/projects/owned": {
      "get": {
        "description": "List all projects the user can administer (owner or admin role)",
        "operationId": "listAdminProjects",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "projects": {
                      "items": {
                        "$ref": "#/components/schemas/Project"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "List of projects"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List admin projects",
        "tags": [
          "projects"
        ]
      }
    },
    "/projects/{project_name}": {
      "delete": {
        "description": "Delete a project (owner only)",
        "operationId": "deleteProject",
        "parameters": [
          {
            "in": "path",
            "name": "project_name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project deleted successfully"
          },
          "403": {
            "description": "Forbidden - owner role required"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Delete project",
        "tags": [
          "projects"
        ]
      },
      "get": {
        "description": "Get project details by name",
        "operationId": "getProject",
        "parameters": [
          {
            "in": "path",
            "name": "project_name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            },
            "description": "Project details"
          },
          "404": {
            "description": "Project not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get project",
        "tags": [
          "projects"
        ]
      },
      "put": {
        "description": "Update project configuration",
        "operationId": "updateProject",
        "parameters": [
          {
            "in": "path",
            "name": "project_name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Project updated successfully"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Update project",
        "tags": [
          "projects"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Development server",
      "url": "http://localhost:8000"
    },
    {
      "description": "Production server",
      "url": "https://frontier.example.com"
    }
  ],
  "tags": [
    {
      "description": "Authentication and user management",
      "name": "auth"
    },
    {
      "description": "Project management and configuration",
      "name": "projects"
    },
    {
      "description": "Chat streaming and message handling",
      "name": "chat"
    },
    {
      "description": "Conversation CRUD operations",
      "name": "conversations"
    },
    {
      "description": "Agent configuration and management",
      "name": "agents"
    },
    {
      "description": "Role-based access control",
      "name": "rbac"
    }
  ]
}
