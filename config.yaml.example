# Frontier configuration file.
# Copy to config.yaml and adjust. If config.yaml is missing, defaults are used.
# Config file path: set CONFIG_FILE env var, or use config.yaml in current working directory.

# Application
app:
  name: Frontier
  splash_text: Welcome to Frontier

# Database (PostgreSQL/YugabyteDB only - SQLite not supported)
# Configure under database.<env> where <env> matches the active environment
database:
  dev:
    host: localhost
    port: 5432
    dbname: frontier
    user: postgres
    credential: password
    schema: public
  # prod:
  #   host: prod-db.example.com
  #   port: 5433
  #   dbname: yugabyte
  #   user: yugabyte
  #   credential: secret
  #   schema: frontier

# JWT authentication
jwt:
  secret_key: change-this-in-production
  expire_minutes: 60

# LDAP (optional)
ldap:
  server: ldap://localhost:1389
  base_dn: dc=example,dc=com
  use_ssl: false
  users_dn: null  # optional; e.g. "uid=%s,ou=users,"

# CORS allowed origins for the API
cors:
  allow_origins:
    - http://localhost:5173
    - http://localhost:3000

# Contact Us configuration
contact:
  # Email support
  email:
    enabled: true
    address: support@example.com
    subject_prefix: "[Frontier Support]"
  # Jira ticket creation
  jira:
    enabled: true
    url: https://your-company.atlassian.net/servicedesk/customer/portal/1/create/10
    button_text: Create Support Ticket

# Admin credentials for sensitive operations (e.g., delete project API)
admin:
  username: admin
  password: change-this-in-production

# Server configuration (gunicorn + uvicorn workers in production)
server:
  workers: 1                    # Number of worker processes (increase for production)
  reload: false                 # Hot-reload dev mode (uses uvicorn directly, single worker)
  timeout: 120                  # Worker heartbeat timeout — gunicorn kills silent workers after N seconds
  graceful_timeout: 30          # Seconds to finish in-flight requests after SIGTERM
  keep_alive: 5                 # Seconds to keep idle HTTP connections open
  max_requests: 0               # Restart worker after N requests (0 = never, prevents memory leaks)
  max_requests_jitter: 0        # Random jitter on max_requests to avoid thundering herd
  backlog: 2048                 # TCP connection backlog queue size
  access_log: false             # Enable HTTP access logging to stdout

# Logging configuration
logging:
  level: INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
