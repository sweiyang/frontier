        end
    end

    subgraph data["Data Layer"]
        db[("YugabyteDB<br/>PostgreSQL-compatible")]
        nfs["File Storage<br/>NFS / Object Store"]
    end

    ldap["LDAP / AD<br/>Corporate Directory"]
    agents["AI Agent Services<br/>LangGraph, OpenAI, Custom HTTP"]

    users -->|"Static assets / HTTPS"| serve_spa
    users -->|"API requests / HTTPS"| serve_api

    api_r1 & api_r2 & api_rn -->|PostgreSQL| db
    api_r1 & api_r2 & api_rn -->|File I/O| nfs
